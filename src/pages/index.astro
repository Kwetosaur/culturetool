---
const base = import.meta.env.BASE_URL;

const mythologies = [
  { slug: 'mythologie-nordique.html', title: 'Nordique', hook: 'Neuf mondes suspendus à un frêne cosmique.', epigraph: 'ᚱᚢᚾᛖᛊ' },
  { slug: 'mythologie-grecque.html', title: 'Grecque', hook: "Sept royaumes primordiaux, l'Olympe et les Enfers.", epigraph: 'ΘΕΟΙ' },
  { slug: 'mythologie-egyptienne.html', title: 'Égyptienne', hook: 'Le Nil, le Douat et la pesée du cœur.', epigraph: '𓁢𓂀𓆣' },
  { slug: 'mythologie-romaine.html', title: 'Romaine', hook: 'Un panthéon hérité, une religion d’État.', epigraph: 'S P Q R' },
  { slug: 'mythologie-celtique.html', title: 'Celtique', hook: "Six vagues d'invasions, un Autre Monde.", epigraph: 'ᚑᚌᚐᚋ' },
  { slug: 'mythologie-mesopotamienne.html', title: 'Mésopotamienne', hook: 'Les premières villes, les premiers mythes écrits.', epigraph: '𒀭𒈗𒆠' },
  { slug: 'mythologie-hindoue.html', title: 'Hindoue', hook: 'Quatorze mondes, un cycle cosmique sans fin.', epigraph: 'ॐ' },
  { slug: 'mythologie-japonaise.html', title: 'Japonaise', hook: 'Huit millions de kami, du ciel aux sanctuaires.', epigraph: '八百万の神' },
  { slug: 'mythologie-azteque-maya.html', title: 'Aztèque & Maya', hook: 'Deux cosmologies voisines, un même continent.', epigraph: 'ⓖ ⓔ' },
  { slug: 'mythologie-slave.html', title: 'Slave', hook: "Le monde visible et l'invisible, Yav et Nav.", epigraph: 'БОГИ' },
];
---

<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mythologies & Cultures du Monde</title>
  <meta name="description" content="Une encyclopédie illustrée des grandes mythologies du monde — cosmogonies, panthéons, légendes et héritages, culture par culture." />
  <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&family=Cinzel:wght@400;600;700&family=EB+Garamond:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #10131c;
      --bg-deep: #0a0c13;
      --panel: #171b28;
      --panel-border: #2a2f42;
      --gold: #c9982f;
      --gold-bright: #e8c164;
      --text: #e9e6db;
      --text-dim: #9a9bb0;
      --glow: rgba(201, 152, 47, 0.25);
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      background:
        radial-gradient(ellipse at top, #1a1f30 0%, var(--bg) 55%),
        var(--bg-deep);
      color: var(--text);
      font-family: 'EB Garamond', Georgia, serif;
      font-size: 18px;
      line-height: 1.7;
    }
    h1, h2, h3 { font-family: 'Cinzel', serif; color: var(--gold-bright); letter-spacing: 0.03em; }
    a { color: var(--gold-bright); }

    header.hero {
      text-align: center;
      padding: 100px 20px 70px;
      max-width: 900px;
      margin: 0 auto;
    }
    .kicker {
      font-family: 'Cinzel', serif;
      letter-spacing: 0.35em;
      font-size: 0.8rem;
      color: var(--gold);
      text-transform: uppercase;
    }
    h1.title {
      font-family: 'Cinzel Decorative', serif;
      font-size: clamp(2.2rem, 6vw, 3.6rem);
      margin: 18px 0 10px;
      text-shadow: 0 0 40px var(--glow);
    }
    .tagline {
      font-size: 1.15rem;
      color: var(--text-dim);
      font-style: italic;
      max-width: 640px;
      margin: 0 auto;
    }
    .divider {
      width: 120px;
      height: 2px;
      margin: 34px auto;
      background: linear-gradient(90deg, transparent, var(--gold), transparent);
    }
    .map-link {
      display: inline-block;
      margin-top: 30px;
      padding: 10px 22px;
      border: 1px solid var(--panel-border);
      border-radius: 6px;
      font-family: 'Cinzel', serif;
      font-size: 0.85rem;
      letter-spacing: 0.04em;
      text-decoration: none;
      color: var(--text);
      transition: border-color 0.2s ease, color 0.2s ease;
    }
    .map-link:hover { border-color: var(--gold); color: var(--gold-bright); }

    section { max-width: 1180px; margin: 0 auto; padding: 40px 24px 90px; }
    .section-label {
      font-family: 'Cinzel', serif;
      letter-spacing: 0.25em;
      font-size: 0.75rem;
      color: var(--gold);
      text-transform: uppercase;
      text-align: center;
      margin-bottom: 8px;
    }
    h2.section-title { text-align: center; font-size: 1.9rem; margin: 0 0 14px; }
    p.section-intro {
      text-align: center;
      color: var(--text-dim);
      max-width: 640px;
      margin: 0 auto 50px;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 22px;
    }
    .card {
      display: block;
      text-decoration: none;
      background: linear-gradient(160deg, var(--panel), var(--bg-deep));
      border: 1px solid var(--panel-border);
      border-radius: 6px;
      padding: 26px 24px;
      transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    }
    .card:hover {
      transform: translateY(-4px);
      border-color: var(--gold);
      box-shadow: 0 10px 30px rgba(0,0,0,0.4);
    }
    .card .epigraph { font-size: 0.85rem; color: var(--gold); letter-spacing: 0.15em; margin-bottom: 10px; }
    .card h3 { margin: 0 0 8px; font-size: 1.3rem; color: var(--text); }
    .card p { margin: 0; color: var(--text-dim); font-size: 0.95rem; }

    .placeholder-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 18px;
    }
    .placeholder-card {
      border: 1px dashed var(--panel-border);
      border-radius: 6px;
      padding: 22px 20px;
      color: var(--text-dim);
      background: rgba(255,255,255,0.02);
    }
    .placeholder-card h4 { margin: 0 0 6px; color: var(--text-dim); font-family: 'Cinzel', serif; font-size: 1.05rem; }
    .placeholder-card span.tag {
      display: inline-block;
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--gold);
      border: 1px solid var(--panel-border);
      border-radius: 3px;
      padding: 2px 8px;
      margin-top: 10px;
    }

    footer {
      text-align: center;
      padding: 50px 20px 80px;
      color: var(--text-dim);
      font-size: 0.9rem;
    }

    @media (max-width: 640px) {
      header.hero { padding: 70px 18px 50px; }
      section { padding: 20px 18px 60px; }
    }
  </style>
</head>
<body data-egg="accueil">
  <header class="hero">
    <div class="kicker">Encyclopédie illustrée</div>
    <h1 class="title">Mythologies &amp; Cultures du Monde</h1>
    <div class="divider"></div>
    <p class="tagline">Cosmogonies, panthéons, généalogies, créatures, légendes, frises et héritages — une traversée culture par culture, chacune racontée à sa juste mesure.</p>
    <a href={`${base}map.html`} class="map-link">🗺️ Voir la carte du monde</a>
  </header>

  <section id="mythologies">
    <div class="section-label">Série en cours</div>
    <h2 class="section-title">Dix Mythologies</h2>
    <p class="section-intro">Chaque chapitre a sa propre cosmologie, son propre panthéon, son propre décor — le nombre de royaumes ou l'ampleur de la frise varient selon ce que chaque culture porte vraiment, sans moule imposé.</p>
    <div class="grid">
      {mythologies.map((m) => (
        <a class="card" href={`${base}${m.slug}`}>
          <div class="epigraph">{m.epigraph}</div>
          <h3>{m.title}</h3>
          <p>{m.hook}</p>
        </a>
      ))}
    </div>
  </section>

  <section id="cultures">
    <div class="section-label">Nouvelle série</div>
    <h2 class="section-title">Cultures du Monde</h2>
    <p class="section-intro">Des peuples, continents et pays entiers racontés au-delà de leur mythologie : histoire, figures, inventions, style de vie.</p>
    <div class="grid">
      <a class="card" href={`${base}culture-chinoise.html`}>
        <div class="epigraph">中國</div>
        <h3>Chine</h3>
        <p>Peuples, grandes figures, inventions et carte-récit d'une civilisation continue.</p>
      </a>
      <a class="card" href={`${base}culture-egypte-antique.html`}>
        <div class="epigraph">𓁢𓂀𓆣</div>
        <h3>Égypte Antique</h3>
        <p>Pharaons, société, inventions et vie quotidienne le long du Nil.</p>
      </a>
    </div>
  </section>

  <section id="creatures">
    <div class="section-label">Nouvelle série</div>
    <h2 class="section-title">Créatures Légendaires</h2>
    <p class="section-intro">Entre folklore, fait divers historique et zoologie mystérieuse — ce qu'on sait vraiment, et ce qu'on raconte.</p>
    <div class="grid">
      <a class="card" href={`${base}creature-gevaudan.html`}>
        <div class="epigraph">1764 — 1767</div>
        <h3>La Bête du Gévaudan</h3>
        <p>Un carnage bien réel dans la France de Louis XV, entre loups, dressage et légende.</p>
      </a>
      <a class="card" href={`${base}creature-loch-ness.html`}>
        <div class="epigraph">Écosse</div>
        <h3>Le Monstre du Loch Ness</h3>
        <p>Photos truquées, sonars et ADN environnemental : l'enquête la plus célèbre du genre.</p>
      </a>
    </div>
  </section>

  <section id="mysteres">
    <div class="section-label">Nouvelle série</div>
    <h2 class="section-title">Grands Mystères</h2>
    <p class="section-intro">Lieux, objets et événements non résolus — ou résolus, mais jamais rattrapés par leur légende.</p>
    <div class="grid">
      <a class="card" href={`${base}mystere-triangle-bermudes.html`}>
        <div class="epigraph">Atlantique Nord</div>
        <h3>Le Triangle des Bermudes</h3>
        <p>Comment la statistique a dégonflé l'un des plus grands mythes médiatiques du XXe siècle.</p>
      </a>
      <a class="card" href={`${base}mystere-stonehenge.html`}>
        <div class="epigraph">Plaine de Salisbury</div>
        <h3>Stonehenge</h3>
        <p>Comment des pierres de plusieurs tonnes ont voyagé 225 km sans roue ni métal.</p>
      </a>
    </div>
  </section>

  <section id="a-venir">
    <div class="section-label">Bientôt</div>
    <h2 class="section-title">La Suite</h2>
    <p class="section-intro">Toutes les séries s'étoffent une entrée à la fois, au rythme des crédits du jour.</p>
    <div class="placeholder-grid">
      <div class="placeholder-card">
        <h4>Prochaines mythologies</h4>
        <p>Chinoise, perse, yoruba, inca, aborigène australienne...</p>
        <span class="tag">Mythologies</span>
      </div>
      <div class="placeholder-card">
        <h4>Prochaines cultures</h4>
        <p>Rome antique, Grèce antique, Japon, empire aztèque...</p>
        <span class="tag">Cultures</span>
      </div>
      <div class="placeholder-card">
        <h4>Prochaines créatures</h4>
        <p>Bigfoot, le Yeti, le Chupacabra, le Mothman...</p>
        <span class="tag">Créatures</span>
      </div>
      <div class="placeholder-card">
        <h4>Prochains mystères</h4>
        <p>Le manuscrit de Voynich, les lignes de Nazca, le col Dyatlov...</p>
        <span class="tag">Mystères</span>
      </div>
    </div>
  </section>

  <footer>
    Site personnel — mythologies et cultures du monde.
  </footer>
  <script src={`${base}effects.js`} defer></script>
</body>
</html>
